# --- App ---
APP_NAME=Full Stack Academy RAG Chatbot
DEBUG=False
PORT=8000

# Comma-separated allowed CORS origins, or * for all (dev only)
ALLOWED_ORIGINS=*

# --- Secrets (DO NOT COMMIT real values) ---
GROQ_API_KEY=your_groq_api_key_here
HF_TOKEN=your_huggingface_token_here

# --- Embeddings (model and dim MUST match; rebuild index if you change these) ---
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIM=768

# --- LLM ---
LLM_MODEL=llama-3.1-8b-instant
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1000

# --- Retrieval ---
RETRIEVAL_K=8
MAX_MESSAGE_LENGTH=2000

# --- Rate limiting (requests per client IP per minute) ---
RATE_LIMIT_PER_MINUTE=20
